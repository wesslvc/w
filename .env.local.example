# Google Drive API 설정
# Google Cloud Console에서 발급한 API Key
GOOGLE_API_KEY=your_api_key_here

# 검색 대상 구글드라이브 폴더 ID
# 폴더 URL의 마지막 부분: https://drive.google.com/drive/folders/[THIS_PART]
DRIVE_FOLDER_ID=your_folder_id_here

# PDF 본문 텍스트 추출 여부 (true/false)
# true로 설정하면 동기화 시 PDF 다운로드 → 텍스트 추출 → 인덱스에 저장
EXTRACT_PDF=false
